{
  "manifest_version": 3,
  "name": "PocketOption OTC Trading Bot",
  "version": "1.0.0",
  "description": "Automated OTC trading bot for Pocket Option — RSI/EMA/MACD/BB multi-strategy with WebSocket interception",
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://pocketoption.com/*",
    "https://*.pocketoption.com/*",
    "https://po.market/*",
    "https://*.po.market/*"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://pocketoption.com/*",
        "https://*.pocketoption.com/*",
        "https://po.market/*",
        "https://*.po.market/*"
      ],
      "js": ["content/bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/content.js", "lib/*.js"],
      "matches": [
        "https://pocketoption.com/*",
        "https://*.pocketoption.com/*",
        "https://po.market/*",
        "https://*.po.market/*"
      ]
    }
  ]
}
